# Alpha Vantage API Key (Get free at https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# MetaTrader 5 Configuration (Demo Account)
MT5_LOGIN=your_mt5_demo_login
MT5_PASSWORD=your_mt5_demo_password
MT5_SERVER=your_mt5_broker_server

# Database Configuration
DATABASE_URL=sqlite:///trading.db

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Secret Key for authentication
SECRET_KEY=your_secret_key_here_generate_with_python_secrets

# App Configuration
APP_NAME=Trading Tool
APP_VERSION=1.0.0
DEBUG=True

# Dashboard Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Data Update Interval (in minutes)
DATA_UPDATE_INTERVAL=5

# Risk Management
DEFAULT_RISK_PER_TRADE=0.02
DEFAULT_MAX_POSITIONS=5

# Email Alerts
EMAIL_ENABLED=false
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=your-email@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Webhook Alerts
WEBHOOK_URL=https://your-webhook-url.com/alerts

# Alert Settings
ALERT_CHECK_INTERVAL=60
